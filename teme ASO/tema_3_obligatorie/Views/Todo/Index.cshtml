@model IEnumerable<TodoItem>
@{
    ViewData["Title"] = "Todo List";
    var filter = ViewBag.Filter as string ?? "all";
    int total     = ViewBag.TotalCount;
    int completed = ViewBag.CompletedCount;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>My Tasks</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Task</a>
</div>

<div class="mb-3 d-flex gap-2 align-items-center">
    <span class="text-muted">@completed / @total completed</span>
    <div class="progress flex-grow-1" style="height: 8px;">
        <div class="progress-bar bg-success" style="width: @(total == 0 ? 0 : completed * 100 / total)%"></div>
    </div>
</div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <a class="nav-link @(filter == "all" ? "active" : "")" asp-action="Index" asp-route-filter="all">All</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(filter == "active" ? "active" : "")" asp-action="Index" asp-route-filter="active">Active</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(filter == "completed" ? "active" : "")" asp-action="Index" asp-route-filter="completed">Completed</a>
    </li>
</ul>

@if (!Model.Any())
{
    <div class="alert alert-secondary text-center">No tasks found.</div>
}
else
{
    <div class="list-group">
        @foreach (var item in Model)
        {
            <div class="list-group-item d-flex align-items-start gap-3 @(item.IsCompleted ? "bg-light" : "")">
                <form asp-action="Toggle" asp-route-id="@item.Id" method="post" class="mt-1">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm @(item.IsCompleted ? "btn-success" : "btn-outline-secondary")"
                            title="@(item.IsCompleted ? "Mark as active" : "Mark as done")">
                        @(item.IsCompleted ? "✓" : "○")
                    </button>
                </form>

                <div class="flex-grow-1">
                    <div class="@(item.IsCompleted ? "text-decoration-line-through text-muted" : "fw-semibold")">
                        @item.Title
                    </div>
                    @if (!string.IsNullOrWhiteSpace(item.Description))
                    {
                        <div class="text-muted small">@item.Description</div>
                    }
                    <div class="text-muted" style="font-size: 0.75rem;">
                        Created: @item.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                        @if (item.CompletedAt.HasValue)
                        {
                            <span class="ms-2">Completed: @item.CompletedAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                        }
                    </div>
                </div>

                <div class="d-flex gap-1">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </div>
            </div>
        }
    </div>
}
